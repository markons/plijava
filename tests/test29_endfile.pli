test29: proc options(main);
    dcl line char(80);
    dcl buf char(80);
    dcl done fixed bin(15) init(0);
    dcl count fixed bin(15) init(0);
    open file('eoftest') output;
    buf = 'line one';
    write file('eoftest') from(buf);
    buf = 'line two';
    write file('eoftest') from(buf);
    buf = 'line three';
    write file('eoftest') from(buf);
    close file('eoftest');
    open file('eoftest') input;
    on endfile('eoftest') done = 1;
    do while(done = 0);
        read file('eoftest') into(line);
        if done = 0 then count = count + 1; else done = done;
    end;
    close file('eoftest');
    put skip list('lines read:', count);
end test29;
